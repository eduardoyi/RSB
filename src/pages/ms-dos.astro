---
import DesktopLayout from '../layouts/DesktopLayout.astro';
import Window from '../components/Window.astro';
---
<DesktopLayout title="MS-DOS Prompt — Real Serious Business">
  <Window
    title="MS-DOS Prompt"
    icon="/icons/win98/ms-dos.ico"
    path="/ms-dos"
    backHref="/"
    defaultWidth={640}
    defaultHeight={420}
    defaultX={80}
    defaultY={60}
    noBodyScroll={true}
  >
    <!-- Source text the terminal types out, word by word -->
    <div id="dos-src" aria-hidden="true" style="display:none">INITIALIZING SYS KERNEL v4.10.1998 BYPASS FIREWALL 192.168.1.1 OK ACCESSING MAINFRAME GRANTED root@localhost:~# nmap -sS -O 192.168.0.0/24 Starting Nmap 7.94 scan report HOST_UP latency 0.0042s PORT STATE SERVICE 22/tcp open ssh 80/tcp open http 443/tcp open https 3306/tcp open mysql 8080/tcp open proxy # cat /etc/shadow | grep -v nologin root:$6$xyz$abc1234567890:19000:0:99999:7::: daemon:*:18375:0:99999:7::: # id && whoami uid=0(root) gid=0(root) root # find / -name "*.key" 2>/dev/null /etc/ssl/private/server.key /home/user/.ssh/id_rsa # openssl rsautl -decrypt -inkey server.key -in secret.enc DECRYPTED: PASSWORD=H4X0R_1998 # hexdump -C /dev/mem 00000000 53 ff 00 f0 53 ff 00 f0 c3 e2 00 f0 53 ff 00 f0 00000010 a0 5d 00 f0 70 60 00 f0 00 00 00 00 00 00 00 00 00000020 ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff # traceroute mainframe.gov 1 192.168.1.1 1.234ms 2 10.0.0.1 8.456ms 3 72.14.192.1 12.789ms 4 mainframe.gov 15.123ms # nc -lvnp 4444 Listening on 0.0.0.0:4444 Connection received SHELL SPAWNED uid=0 PRIVILEGE ESCALATION COMPLETE DOWNLOADING DATABASE [####################] 100% 2.4GB ENCRYPTING PAYLOAD AES-256-CBC COVERING TRACKS rm -rf /var/log/* /tmp/.session history -c MISSION COMPLETE ACCESS GRANTED WELCOME BACK INITIATING PHASE TWO UPLINK ESTABLISHED SATELLITE LOCKED TARGET ACQUIRED EXECUTING PAYLOAD KERNEL PANIC... just kidding :) REBOOTING MAINFRAME SYNCHRONIZING CLOCKS INJECTING SHELLCODE 0x41414141 BUFFER OVERFLOW DETECTED BYPASSING CANARY NOP SLED PLACED RET2LIBC GADGET FOUND STACK PIVOTED SIGRETURN CHAINED GOT OVERWRITE CONFIRMED LIBC BASE 0x7f3a2b1c0000 SYSTEM CALL rax=59 rdi=/bin/sh EXECVE ROOT SHELL OBTAINED</div>

    <div id="dos-terminal" tabindex="0">
      <span id="dos-output"></span><span class="dos-cursor" aria-hidden="true">_</span>
    </div>

    <p id="dos-hint" aria-live="polite">PRESS ANY KEY TO BEGIN_</p>
  </Window>
</DesktopLayout>

<style>
  /* window-body with noBodyScroll is already flex column overflow:hidden */
  :global(.w98-window.no-body-scroll .window-body) {
    position: relative;
  }

  #dos-terminal {
    flex: 1;
    background: #000;
    color: #c0c0c0;
    font-family: 'Courier New', 'Lucida Console', monospace;
    font-size: 14px;
    line-height: 1.5;
    padding: 6px 10px;
    overflow-y: auto;
    cursor: text;
    outline: none;
    white-space: pre-wrap;
    word-break: break-all;
    -webkit-tap-highlight-color: transparent;
  }

  .dos-cursor {
    animation: dos-blink 1s step-end infinite;
  }

  @keyframes dos-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  #dos-hint {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    color: #808080;
    background: #000;
    padding: 4px 0;
    pointer-events: none;
    animation: dos-blink 1s step-end infinite;
    margin: 0;
  }

  #dos-hint.hidden {
    display: none;
  }
</style>

<script is:inline>
(function () {
  var src = document.getElementById('dos-src').textContent.trim();
  var words = src.split(/(?= )/); // split before each space, keeping the space
  var idx = 0;

  var outputEl = document.getElementById('dos-output');
  var terminal = document.getElementById('dos-terminal');
  var hint = document.getElementById('dos-hint');

  var SCRAMBLE = '!<>-_\\/[]{}=+*^?#@$%&ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
  var FRAMES = 5;
  var TICK = 22; // ms per scramble frame

  function appendWord(word) {
    var span = document.createElement('span');
    outputEl.appendChild(span);

    var frame = 0;
    var iv = setInterval(function () {
      if (frame < FRAMES) {
        // scramble: show random chars of same length
        var fake = '';
        for (var i = 0; i < word.length; i++) {
          fake += word[i] === ' ' ? ' ' : SCRAMBLE[Math.floor(Math.random() * SCRAMBLE.length)];
        }
        span.textContent = fake;
        frame++;
      } else {
        clearInterval(iv);
        span.textContent = word;
        terminal.scrollTop = terminal.scrollHeight;
      }
    }, TICK);
  }

  function onKey(e) {
    // ignore modifier-only keys
    if (['Shift', 'Control', 'Alt', 'Meta', 'CapsLock', 'Tab'].indexOf(e.key) !== -1) return;

    hint.classList.add('hidden');
    appendWord(words[idx % words.length]);
    idx++;
  }

  // focus & listen
  terminal.addEventListener('click', function () { terminal.focus(); });
  terminal.addEventListener('touchend', function (e) { e.preventDefault(); terminal.focus(); });
  terminal.addEventListener('keydown', onKey);

  // on mobile, a tap focuses but we need a real input to pull up the keyboard
  // create a hidden input that focuses on terminal tap
  var inp = document.createElement('input');
  inp.setAttribute('type', 'text');
  inp.setAttribute('inputmode', 'text');
  inp.style.cssText = 'position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;top:0;left:0;';
  document.body.appendChild(inp);

  function focusMobile() {
    inp.focus();
    terminal.focus();
  }

  inp.addEventListener('keydown', onKey);
  inp.addEventListener('input', function () {
    // each character typed on mobile fires input; treat as one keypress
    if (inp.value.length > 0) {
      inp.value = '';
      onKey({ key: 'char' });
    }
  });

  terminal.addEventListener('click', function () { inp.focus(); });
  terminal.addEventListener('touchend', function (e) { e.preventDefault(); inp.focus(); });

  terminal.focus();
})();
</script>
