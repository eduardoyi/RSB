---
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Media — Real Serious Business</title>
  <style is:inline>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --surface-base: #f8f7f5;
      --surface-card: #ffffff;
      --surface-sunken: #f0efec;
      --surface-header: #1a1a1a;
      --text-primary: #1a1a1a;
      --text-secondary: #6b6560;
      --text-tertiary: #9b9590;
      --accent: #2a7c6f;
      --accent-hover: #1f5f55;
      --accent-subtle: #e8f4f1;
      --danger: #c0392b;
      --border-default: #e2e0dc;
      --radius-md: 6px;
      --shadow-sm: 0 1px 2px rgba(0,0,0,.05);
      --shadow-md: 0 2px 8px rgba(0,0,0,.08);
      --shadow-lg: 0 4px 16px rgba(0,0,0,.12);
      --shadow-focus: 0 0 0 3px rgba(42,124,111,.2);
      --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-mono: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }

    body {
      font-family: var(--font-sans);
      font-size: 14px;
      background: var(--surface-base);
      color: var(--text-primary);
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ── */
    .header {
      background: var(--surface-header);
      color: #fff;
      padding: 0 20px;
      height: 48px;
      display: flex;
      align-items: center;
      gap: 0;
      flex-shrink: 0;
    }
    .header-monogram {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .5px;
      color: rgba(255,255,255,.5);
      margin-right: 24px;
    }
    .header-nav {
      display: flex;
      gap: 0;
      height: 100%;
    }
    .header-nav a {
      display: flex;
      align-items: center;
      padding: 0 16px;
      color: rgba(255,255,255,.65);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      height: 100%;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
    }
    .header-nav a:hover { color: #fff; }
    .header-nav a.active {
      color: #fff;
      border-bottom-color: var(--accent);
    }
    .header-spacer { flex: 1; }
    .header .btn-logout {
      background: none;
      border: 1px solid rgba(255,255,255,.2);
      color: rgba(255,255,255,.65);
      padding: 5px 12px;
      border-radius: var(--radius-md);
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      transition: color .15s, border-color .15s;
    }
    .header .btn-logout:hover {
      color: #fff;
      border-color: rgba(255,255,255,.4);
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0 14px;
      height: 36px;
      border-radius: var(--radius-md);
      border: 1px solid transparent;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      transition: background .15s, border-color .15s, box-shadow .15s, transform .1s;
    }
    .btn:active { transform: translateY(1px); }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
      border-bottom: 2px solid var(--accent-hover);
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-primary:disabled {
      opacity: .6;
      cursor: not-allowed;
      transform: none;
    }
    .btn-secondary {
      background: var(--surface-card);
      color: var(--text-primary);
      border-color: var(--border-default);
    }
    .btn-secondary:hover { background: var(--surface-sunken); }
    .btn-danger {
      background: var(--surface-card);
      color: var(--danger);
      border-color: var(--danger);
    }
    .btn-danger:hover { background: #fdf0ef; }

    /* ── Toolbar ── */
    .toolbar {
      background: var(--surface-card);
      border-bottom: 1px solid var(--border-default);
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .search-wrap {
      position: relative;
    }
    .search-wrap::before {
      content: '\1F50D';
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 13px;
      pointer-events: none;
    }
    .search-input {
      padding: 0 10px 0 32px;
      height: 36px;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      font-size: 13px;
      width: 240px;
      font-family: inherit;
      background: var(--surface-card);
      color: var(--text-primary);
    }
    .search-input::placeholder { color: var(--text-tertiary); }
    .search-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: var(--shadow-focus);
    }

    /* ── Filter pills ── */
    .filter-pills {
      display: flex;
      gap: 0;
      background: var(--surface-sunken);
      border-radius: var(--radius-md);
      padding: 2px;
    }
    .filter-pill {
      padding: 5px 14px;
      font-size: 12px;
      font-weight: 500;
      border: none;
      background: none;
      color: var(--text-secondary);
      cursor: pointer;
      border-radius: 4px;
      font-family: inherit;
      transition: background .15s, color .15s;
    }
    .filter-pill:hover { color: var(--text-primary); }
    .filter-pill.active {
      background: var(--surface-card);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }

    .status-text {
      color: var(--text-secondary);
      font-size: 12px;
      margin-left: auto;
    }

    /* ── Auth screen ── */
    #auth-screen {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .auth-card {
      background: var(--surface-card);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      padding: 36px;
      width: 340px;
      box-shadow: var(--shadow-md);
    }
    .auth-site-name {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-tertiary);
      margin-bottom: 4px;
    }
    .auth-card h2 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 20px;
      color: var(--text-primary);
    }
    .auth-card input {
      width: 100%;
      padding: 0 12px;
      height: 36px;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      font-size: 13px;
      margin-bottom: 14px;
      font-family: inherit;
      color: var(--text-primary);
    }
    .auth-card input::placeholder { color: var(--text-tertiary); }
    .auth-card input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: var(--shadow-focus);
    }
    .auth-card .btn { width: 100%; justify-content: center; }
    .auth-error {
      color: var(--danger);
      font-size: 12px;
      margin-bottom: 12px;
      display: none;
    }
    .auth-error.visible { display: block; }

    /* ── Main layout ── */
    #main-screen { flex: 1; display: none; flex-direction: column; overflow: hidden; }

    /* ── Upload zone ── */
    .upload-zone {
      border: 2px dashed var(--border-default);
      border-radius: var(--radius-md);
      padding: 12px 16px;
      text-align: center;
      margin: 12px 20px;
      cursor: pointer;
      color: var(--text-secondary);
      transition: border-color .2s, background .2s, padding .3s, max-height .3s;
      flex-shrink: 0;
      font-size: 13px;
      max-height: 50px;
      overflow: hidden;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      border-color: var(--accent);
      background: var(--accent-subtle);
      color: var(--accent);
    }
    .upload-zone.expanded {
      max-height: 400px;
      padding: 16px;
    }
    .upload-zone input { display: none; }
    .upload-zone-label {
      color: var(--accent);
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .upload-progress-list {
      margin-top: 12px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .upload-progress-row {
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--surface-card);
      border: 1px solid var(--border-default);
      border-radius: 4px;
      padding: 6px 10px;
      font-size: 12px;
      text-align: left;
    }
    .upload-progress-row .filename {
      flex: 1;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--text-primary);
    }
    .upload-progress-row .progress-bar-wrap {
      width: 100px;
      height: 4px;
      background: var(--surface-sunken);
      border-radius: 2px;
      overflow: hidden;
    }
    .upload-progress-row .progress-bar {
      height: 100%;
      background: var(--accent);
      border-radius: 2px;
      transition: width .2s;
    }
    .upload-progress-row .status-icon {
      font-size: 14px;
      width: 18px;
      text-align: center;
    }

    /* ── Grid + detail pane ── */
    .content-area {
      flex: 1;
      display: flex;
      overflow: hidden;
    }

    .grid-wrap {
      flex: 1;
      overflow: auto;
      min-width: 0;
      padding: 0 20px 20px;
    }

    .media-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 10px;
    }

    .media-item {
      background: var(--surface-card);
      border: 2px solid var(--border-default);
      border-radius: var(--radius-md);
      cursor: pointer;
      overflow: hidden;
      transition: border-color .15s, box-shadow .15s, transform .15s;
      min-width: 0;
      opacity: 0;
      animation: fadeInItem .3s ease forwards;
    }
    .media-item:hover {
      border-color: var(--accent);
      box-shadow: var(--shadow-md);
    }
    .media-item:hover .media-thumb-wrap img {
      transform: scale(1.02);
    }
    .media-item.selected {
      border-color: var(--accent);
      background: var(--accent-subtle);
      box-shadow: 0 0 0 1px var(--accent);
    }

    @keyframes fadeInItem {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .media-thumb-wrap {
      height: 120px;
      overflow: hidden;
      background: var(--surface-sunken);
    }
    .media-thumb-wrap img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .2s;
    }
    .media-icon {
      width: 100%;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--surface-sunken);
      font-size: 36px;
    }
    .media-name {
      font-size: 11px;
      padding: 6px 8px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      border-top: 1px solid var(--border-default);
      color: var(--text-secondary);
    }

    /* ── Skeleton loading ── */
    .skeleton-item {
      background: var(--surface-card);
      border: 2px solid var(--border-default);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .skeleton-thumb {
      height: 120px;
      background: linear-gradient(90deg, var(--surface-sunken) 25%, #e8e7e4 50%, var(--surface-sunken) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    .skeleton-name {
      height: 11px;
      margin: 8px 8px;
      background: var(--surface-sunken);
      border-radius: 3px;
      width: 60%;
    }

    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    /* ── Detail sidebar ── */
    .detail-pane {
      width: 320px;
      flex-shrink: 0;
      border-left: 1px solid var(--border-default);
      background: var(--surface-card);
      overflow-y: auto;
      display: none;
      flex-direction: column;
      transform: translateX(20px);
      opacity: 0;
      transition: transform .25s ease, opacity .25s ease;
    }
    .detail-pane.visible {
      display: flex;
      transform: translateX(0);
      opacity: 1;
    }
    .detail-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border-default);
    }
    .detail-header-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-secondary);
    }
    .detail-close {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: none;
      cursor: pointer;
      border-radius: 4px;
      font-size: 18px;
      color: var(--text-secondary);
      transition: background .15s, color .15s;
    }
    .detail-close:hover {
      background: var(--surface-sunken);
      color: var(--text-primary);
    }
    .detail-preview {
      width: 100%;
      max-width: 100%;
      max-height: 250px;
      object-fit: contain;
      display: block;
      background-image: linear-gradient(45deg, #e8e7e4 25%, transparent 25%),
        linear-gradient(-45deg, #e8e7e4 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #e8e7e4 75%),
        linear-gradient(-45deg, transparent 75%, #e8e7e4 75%);
      background-size: 16px 16px;
      background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
    }
    .detail-icon {
      width: 100%;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--surface-sunken);
      font-size: 48px;
    }
    .detail-body { padding: 16px; flex: 1; }
    .detail-body h3 {
      font-size: 14px;
      font-weight: 600;
      word-break: break-all;
      margin-bottom: 16px;
      color: var(--text-primary);
    }
    .detail-meta-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 16px;
    }
    .detail-meta-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
    }
    .detail-meta-label {
      color: var(--text-secondary);
      font-weight: 500;
    }
    .detail-meta-value {
      color: var(--text-primary);
    }
    .detail-url-wrap {
      margin-bottom: 16px;
    }
    .detail-url-label {
      font-size: 11px;
      font-weight: 500;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 4px;
    }
    .detail-url {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      font-size: 11px;
      background: var(--surface-sunken);
      color: var(--text-secondary);
      word-break: break-all;
      font-family: var(--font-mono);
      cursor: pointer;
      transition: background .15s, border-color .15s;
      line-height: 1.5;
    }
    .detail-url:hover {
      border-color: var(--accent);
      background: var(--accent-subtle);
    }
    .detail-url .copied-feedback {
      color: var(--accent);
      font-weight: 600;
      font-family: var(--font-sans);
    }
    .detail-actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    /* ── Picker banner ── */
    .picker-banner {
      background: var(--accent-subtle);
      border-bottom: 1px solid var(--border-default);
      padding: 8px 20px;
      font-size: 12px;
      color: var(--accent-hover);
      display: none;
      flex-shrink: 0;
      font-weight: 500;
    }
    .picker-banner.visible { display: block; }

    /* ── Toast stack ── */
    .toast-container {
      position: fixed;
      bottom: 20px;
      right: 20px;
      display: flex;
      flex-direction: column-reverse;
      gap: 8px;
      z-index: 999;
      pointer-events: none;
    }
    .toast-item {
      background: var(--surface-card);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      padding: 10px 14px;
      font-size: 13px;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 260px;
      max-width: 380px;
      transform: translateX(100%);
      opacity: 0;
      animation: toastIn .25s ease forwards;
      pointer-events: auto;
      position: relative;
      overflow: hidden;
    }
    .toast-item.removing {
      animation: toastOut .2s ease forwards;
    }
    @keyframes toastIn {
      to { transform: translateX(0); opacity: 1; }
    }
    @keyframes toastOut {
      to { transform: translateX(100%); opacity: 0; }
    }
    .toast-item .toast-border {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
    }
    .toast-item.success .toast-border { background: #27ae60; }
    .toast-item.error .toast-border { background: var(--danger); }
    .toast-item.info .toast-border { background: #d4a017; }
    .toast-icon { font-size: 15px; flex-shrink: 0; }
    .toast-message { flex: 1; color: var(--text-primary); }
    .toast-dismiss {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-tertiary);
      font-size: 16px;
      padding: 0 2px;
      line-height: 1;
    }
    .toast-dismiss:hover { color: var(--text-primary); }
    .toast-progress {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 2px;
      background: var(--border-default);
      transition: width linear;
    }

    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 60px 20px;
      color: var(--text-tertiary);
      font-size: 14px;
    }
  </style>
</head>
<body>

  <div class="header" id="header-bar">
    <span class="header-monogram">RSB</span>
    <nav class="header-nav">
      <a href="/admin/assets" class="active">Media</a>
      <a href="/admin/">Content</a>
    </nav>
    <div class="header-spacer"></div>
    <button class="btn-logout" id="logout-btn" style="display:none;">Log out</button>
  </div>

  <div id="picker-banner" class="picker-banner">
    Picker mode — select a file to insert it into the editor.
  </div>

  <!-- Auth screen -->
  <div id="auth-screen">
    <div class="auth-card">
      <div class="auth-site-name">Real Serious Business</div>
      <h2>Media Library</h2>
      <div class="auth-error" id="auth-error">Invalid token. Please try again.</div>
      <input type="password" id="token-input" placeholder="Admin token" />
      <button class="btn btn-primary" id="auth-btn">Connect</button>
    </div>
  </div>

  <!-- Main screen -->
  <div id="main-screen">
    <div class="toolbar">
      <label class="btn btn-primary" id="upload-btn-toolbar">
        ↑ Upload
        <input type="file" id="file-input-header" style="display:none;" multiple />
      </label>
      <div class="search-wrap">
        <input class="search-input" id="search" type="search" placeholder="Search files…" />
      </div>
      <div class="filter-pills" id="filter-pills">
        <button class="filter-pill active" data-filter="all">All</button>
        <button class="filter-pill" data-filter="image">Images</button>
        <button class="filter-pill" data-filter="audio">Audio</button>
        <button class="filter-pill" data-filter="other">Other</button>
      </div>
      <span class="status-text" id="status-text"></span>
    </div>

    <div class="upload-zone" id="upload-zone">
      Drop files here to upload, or <label class="upload-zone-label" for="file-input-zone">browse</label>
      <input type="file" id="file-input-zone" multiple />
      <div class="upload-progress-list" id="upload-progress-list"></div>
    </div>

    <div class="content-area">
      <div class="grid-wrap">
        <div class="media-grid" id="media-grid"></div>
      </div>

      <!-- Detail sidebar -->
      <div class="detail-pane" id="detail-pane">
        <div class="detail-header">
          <span class="detail-header-title">Details</span>
          <button class="detail-close" id="detail-close" title="Close">&times;</button>
        </div>
        <div id="detail-preview-wrap"></div>
        <div class="detail-body">
          <h3 id="detail-name"></h3>
          <div class="detail-meta-list" id="detail-meta"></div>
          <div class="detail-url-wrap">
            <div class="detail-url-label">URL</div>
            <div class="detail-url" id="detail-url" role="button" tabindex="0"></div>
          </div>
          <div class="detail-actions" id="detail-actions"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toast-container"></div>

  <script define:vars={{ workerUrl: import.meta.env.PUBLIC_R2_WORKER_URL || '' }}>
    const isPicker = new URLSearchParams(location.search).get('picker') === 'true';
    let adminToken = '';
    let allAssets = [];
    let selectedKey = null;
    let activeFilter = 'all';
    let isLoading = false;

    const IMG_EXTS = ['jpg','jpeg','png','gif','webp','svg','avif'];
    const AUDIO_EXTS = ['mp3','m4a','ogg','wav','flac'];

    function fileType(key) {
      const ext = key.split('.').pop()?.toLowerCase() ?? '';
      if (IMG_EXTS.includes(ext)) return 'image';
      if (AUDIO_EXTS.includes(ext)) return 'audio';
      return 'other';
    }

    function fileIcon(key) {
      const t = fileType(key);
      if (t === 'audio') return '🎵';
      return '📄';
    }

    function formatSize(bytes) {
      if (!bytes) return '—';
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes/1024).toFixed(1) + ' KB';
      return (bytes/1048576).toFixed(1) + ' MB';
    }

    function fileExtension(key) {
      return key.split('.').pop()?.toUpperCase() ?? '—';
    }

    // ── Toast system ─────────────────────────────────────────────────────────
    function toast({ message, type = 'success' }) {
      const container = document.getElementById('toast-container');
      const item = document.createElement('div');
      item.className = `toast-item ${type}`;

      const icons = { success: '✓', error: '✕', info: 'ℹ' };
      item.innerHTML = `
        <div class="toast-border"></div>
        <span class="toast-icon">${icons[type] || icons.info}</span>
        <span class="toast-message">${message}</span>
        ${type === 'error' ? '<button class="toast-dismiss">&times;</button>' : ''}
        ${type !== 'error' ? '<div class="toast-progress"></div>' : ''}
      `;

      container.appendChild(item);

      const dismiss = item.querySelector('.toast-dismiss');
      if (dismiss) {
        dismiss.addEventListener('click', () => removeToast(item));
      }

      if (type !== 'error') {
        const bar = item.querySelector('.toast-progress');
        if (bar) {
          bar.style.width = '100%';
          requestAnimationFrame(() => {
            bar.style.width = '0%';
            bar.style.transitionDuration = '3s';
          });
        }
        setTimeout(() => removeToast(item), 3000);
      }
    }

    function removeToast(item) {
      item.classList.add('removing');
      setTimeout(() => item.remove(), 200);
    }

    // ── Logout ───────────────────────────────────────────────────────────────
    function logout() {
      localStorage.removeItem('rsb:admin-token');
      adminToken = '';
      location.reload();
    }
    document.getElementById('logout-btn').addEventListener('click', logout);

    // ── Auth ──────────────────────────────────────────────────────────────────
    if (isPicker) document.getElementById('picker-banner').classList.add('visible');

    const stored = localStorage.getItem('rsb:admin-token');
    if (stored) {
      adminToken = stored;
      showMain();
      loadAssets(true); // validate token
    }

    document.getElementById('auth-btn').addEventListener('click', doAuth);
    document.getElementById('token-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') doAuth();
    });

    function doAuth() {
      const btn = document.getElementById('auth-btn');
      const input = document.getElementById('token-input');
      adminToken = input.value.trim();
      if (!adminToken) return;

      btn.disabled = true;
      btn.textContent = 'Connecting…';
      document.getElementById('auth-error').classList.remove('visible');

      // Validate token with a test API call
      fetch(`${workerUrl}/api/assets`, {
        headers: { Authorization: `Bearer ${adminToken}` },
      })
        .then(res => {
          if (!res.ok) throw new Error('invalid');
          return res.json();
        })
        .then(data => {
          localStorage.setItem('rsb:admin-token', adminToken);
          allAssets = data;
          showMain();
          renderGrid();
        })
        .catch(() => {
          btn.disabled = false;
          btn.textContent = 'Connect';
          adminToken = '';
          document.getElementById('auth-error').classList.add('visible');
        });
    }

    function showMain() {
      document.getElementById('auth-screen').style.display = 'none';
      document.getElementById('main-screen').style.display = 'flex';
      document.getElementById('logout-btn').style.display = '';
    }

    // ── Load + render ─────────────────────────────────────────────────────────
    async function loadAssets(validate) {
      isLoading = true;
      renderGrid(); // show skeletons
      document.getElementById('status-text').textContent = 'Loading…';
      try {
        const res = await fetch(`${workerUrl}/api/assets`, {
          headers: { Authorization: `Bearer ${adminToken}` },
        });
        if (!res.ok) {
          if (validate && res.status === 401) {
            localStorage.removeItem('rsb:admin-token');
            adminToken = '';
            document.getElementById('auth-screen').style.display = '';
            document.getElementById('main-screen').style.display = 'none';
            document.getElementById('logout-btn').style.display = 'none';
            document.getElementById('auth-error').textContent = 'Session expired. Please reconnect.';
            document.getElementById('auth-error').classList.add('visible');
            return;
          }
          throw new Error(`HTTP ${res.status}`);
        }
        allAssets = await res.json();
        isLoading = false;
        renderGrid();
      } catch(err) {
        isLoading = false;
        document.getElementById('status-text').textContent = 'Error: ' + err.message;
      }
    }

    function currentFilter() {
      const q = document.getElementById('search').value.toLowerCase();
      return allAssets.filter(a =>
        (activeFilter === 'all' || fileType(a.key) === activeFilter) &&
        (!q || a.key.toLowerCase().includes(q))
      );
    }

    function renderGrid() {
      const grid = document.getElementById('media-grid');

      if (isLoading) {
        grid.innerHTML = '';
        for (let i = 0; i < 8; i++) {
          const sk = document.createElement('div');
          sk.className = 'skeleton-item';
          sk.innerHTML = '<div class="skeleton-thumb"></div><div class="skeleton-name"></div>';
          grid.appendChild(sk);
        }
        return;
      }

      const assets = currentFilter();
      document.getElementById('status-text').textContent = `${assets.length} file${assets.length !== 1 ? 's' : ''}`;
      grid.innerHTML = '';

      if (!assets.length) {
        grid.innerHTML = '<div class="empty-state">No files found.</div>';
        return;
      }

      assets.forEach((asset, idx) => {
        const item = document.createElement('div');
        item.className = 'media-item' + (asset.key === selectedKey ? ' selected' : '');
        item.dataset.key = asset.key;
        item.style.animationDelay = `${Math.min(idx * 30, 300)}ms`;

        if (fileType(asset.key) === 'image') {
          const wrap = document.createElement('div');
          wrap.className = 'media-thumb-wrap';
          const img = document.createElement('img');
          img.src = asset.url;
          img.alt = '';
          img.loading = 'lazy';
          wrap.appendChild(img);
          item.appendChild(wrap);
        } else {
          const icon = document.createElement('div');
          icon.className = 'media-icon';
          icon.textContent = fileIcon(asset.key);
          item.appendChild(icon);
        }

        const name = document.createElement('div');
        name.className = 'media-name';
        name.textContent = asset.key;
        item.appendChild(name);

        item.addEventListener('click', () => selectItem(asset));
        grid.appendChild(item);
      });
    }

    function selectItem(asset) {
      selectedKey = asset.key;
      document.querySelectorAll('.media-item').forEach(el =>
        el.classList.toggle('selected', el.dataset.key === asset.key)
      );

      const pane = document.getElementById('detail-pane');
      // Force re-trigger slide animation
      pane.classList.remove('visible');
      requestAnimationFrame(() => pane.classList.add('visible'));

      // Preview
      const previewWrap = document.getElementById('detail-preview-wrap');
      if (fileType(asset.key) === 'image') {
        previewWrap.innerHTML = `<img class="detail-preview" src="${asset.url}" alt="" />`;
      } else {
        previewWrap.innerHTML = `<div class="detail-icon">${fileIcon(asset.key)}</div>`;
      }

      document.getElementById('detail-name').textContent = asset.key;

      // Structured metadata
      const metaEl = document.getElementById('detail-meta');
      metaEl.innerHTML = `
        <div class="detail-meta-row">
          <span class="detail-meta-label">Type</span>
          <span class="detail-meta-value">${fileExtension(asset.key)}</span>
        </div>
        <div class="detail-meta-row">
          <span class="detail-meta-label">Size</span>
          <span class="detail-meta-value">${formatSize(asset.size)}</span>
        </div>
        <div class="detail-meta-row">
          <span class="detail-meta-label">Filename</span>
          <span class="detail-meta-value" style="word-break:break-all;">${asset.key}</span>
        </div>
      `;

      // URL — click to copy
      const urlEl = document.getElementById('detail-url');
      urlEl.textContent = asset.url;
      urlEl.onclick = () => {
        navigator.clipboard.writeText(asset.url).then(() => {
          urlEl.innerHTML = '<span class="copied-feedback">Copied!</span>';
          setTimeout(() => { urlEl.textContent = asset.url; }, 1500);
        });
      };

      const actions = document.getElementById('detail-actions');
      actions.innerHTML = '';

      if (isPicker) {
        const btn = document.createElement('button');
        btn.className = 'btn btn-primary';
        btn.textContent = 'Insert into editor';
        btn.onclick = () => {
          const bc = new BroadcastChannel('r2-picker');
          bc.postMessage({ type: 'r2:select', url: asset.url });
          bc.close();
          window.close();
        };
        actions.appendChild(btn);
      }

      const delBtn = document.createElement('button');
      delBtn.className = 'btn btn-danger';
      delBtn.textContent = 'Delete file';
      delBtn.onclick = () => deleteAsset(asset.key);
      actions.appendChild(delBtn);
    }

    // ── Detail close ─────────────────────────────────────────────────────────
    document.getElementById('detail-close').addEventListener('click', () => {
      selectedKey = null;
      document.getElementById('detail-pane').classList.remove('visible');
      document.querySelectorAll('.media-item.selected').forEach(el => el.classList.remove('selected'));
    });

    async function deleteAsset(key) {
      if (!confirm(`Delete "${key}"?`)) return;
      try {
        const res = await fetch(`${workerUrl}/api/assets/${encodeURIComponent(key)}`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${adminToken}` },
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        toast({ message: 'File deleted.', type: 'success' });
        selectedKey = null;
        document.getElementById('detail-pane').classList.remove('visible');
        loadAssets();
      } catch(err) {
        toast({ message: 'Delete failed: ' + err.message, type: 'error' });
      }
    }

    // ── Upload ────────────────────────────────────────────────────────────────
    async function uploadFiles(files) {
      const zone = document.getElementById('upload-zone');
      const list = document.getElementById('upload-progress-list');

      zone.classList.add('expanded');
      list.innerHTML = '';

      // Create progress rows
      const rows = Array.from(files).map(file => {
        const row = document.createElement('div');
        row.className = 'upload-progress-row';
        row.innerHTML = `
          <span class="filename">${file.name}</span>
          <div class="progress-bar-wrap"><div class="progress-bar" style="width:0%"></div></div>
          <span class="status-icon">⏳</span>
        `;
        list.appendChild(row);
        return { file, row };
      });

      for (const { file, row } of rows) {
        const bar = row.querySelector('.progress-bar');
        const icon = row.querySelector('.status-icon');
        bar.style.width = '30%';

        const form = new FormData();
        form.append('file', file);
        try {
          bar.style.width = '70%';
          const res = await fetch(`${workerUrl}/api/assets/upload`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${adminToken}` },
            body: form,
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          bar.style.width = '100%';
          icon.textContent = '✓';
          icon.style.color = '#27ae60';
        } catch(err) {
          bar.style.width = '100%';
          bar.style.background = 'var(--danger)';
          icon.textContent = '✕';
          icon.style.color = 'var(--danger)';
          toast({ message: `Upload failed: ${file.name}`, type: 'error' });
        }
      }

      toast({ message: `Upload complete.`, type: 'success' });

      // Auto-collapse after a brief delay
      setTimeout(() => {
        zone.classList.remove('expanded');
        list.innerHTML = '';
      }, 2000);

      loadAssets();
    }

    document.getElementById('file-input-header').addEventListener('change', e => uploadFiles(e.target.files));
    document.getElementById('file-input-zone').addEventListener('change', e => uploadFiles(e.target.files));

    const zone = document.getElementById('upload-zone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('drag-over');
      uploadFiles(e.dataTransfer.files);
    });

    // ── Filter pills ─────────────────────────────────────────────────────────
    document.getElementById('filter-pills').addEventListener('click', e => {
      const pill = e.target.closest('.filter-pill');
      if (!pill) return;
      document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeFilter = pill.dataset.filter;
      renderGrid();
    });

    document.getElementById('search').addEventListener('input', renderGrid);
  </script>
</body>
</html>
