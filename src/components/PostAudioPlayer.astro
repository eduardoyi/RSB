---
interface Props {
  src: string;
}
const { src } = Astro.props;
---

<div class="post-audio-player">
  <p class="audio-label">&#127897; Listen to the audio version</p>
  <div class="audio-bar">
    <button class="audio-btn" id="audio-play" title="Play">&#9654;</button>
    <button class="audio-btn" id="audio-pause" title="Pause" style="display:none">&#9646;&#9646;</button>
    <button class="audio-btn" id="audio-stop" title="Stop">&#9632;</button>
    <button class="audio-btn" id="audio-back" title="Back 10s">&#9664;&#9664;</button>
    <button class="audio-btn" id="audio-fwd" title="Forward 30s">&#9654;&#9654;</button>
    <div class="audio-progress-track" id="audio-progress-track">
      <div class="audio-progress-fill" id="audio-progress-fill"></div>
    </div>
    <span class="audio-time" id="audio-time">0:00 / 0:00</span>
    <span class="audio-vol-icon">&#128266;</span>
    <input type="range" class="audio-volume" id="audio-volume" min="0" max="1" step="0.05" value="1" />
  </div>
  <audio id="audio-el" src={src} preload="metadata" style="display:none"></audio>
</div>

<script>
  (function () {
    const container = document.currentScript!.previousElementSibling as HTMLElement | null;
    if (!container) return;

    const audio = container.querySelector<HTMLAudioElement>('#audio-el')!;
    const playBtn = container.querySelector<HTMLButtonElement>('#audio-play')!;
    const pauseBtn = container.querySelector<HTMLButtonElement>('#audio-pause')!;
    const stopBtn = container.querySelector<HTMLButtonElement>('#audio-stop')!;
    const backBtn = container.querySelector<HTMLButtonElement>('#audio-back')!;
    const fwdBtn = container.querySelector<HTMLButtonElement>('#audio-fwd')!;
    const track = container.querySelector<HTMLDivElement>('#audio-progress-track')!;
    const fill = container.querySelector<HTMLDivElement>('#audio-progress-fill')!;
    const timeEl = container.querySelector<HTMLSpanElement>('#audio-time')!;
    const volEl = container.querySelector<HTMLInputElement>('#audio-volume')!;

    function fmt(s: number): string {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function updateTime() {
      const dur = isFinite(audio.duration) ? audio.duration : 0;
      fill.style.width = dur ? `${(audio.currentTime / dur) * 100}%` : '0%';
      timeEl.textContent = `${fmt(audio.currentTime)} / ${fmt(dur)}`;
    }

    function setPlaying(playing: boolean) {
      playBtn.style.display = playing ? 'none' : '';
      pauseBtn.style.display = playing ? '' : 'none';
    }

    playBtn.addEventListener('click', () => { audio.play(); setPlaying(true); });
    pauseBtn.addEventListener('click', () => { audio.pause(); setPlaying(false); });
    stopBtn.addEventListener('click', () => {
      audio.pause();
      audio.currentTime = 0;
      setPlaying(false);
      updateTime();
    });
    backBtn.addEventListener('click', () => { audio.currentTime = Math.max(0, audio.currentTime - 10); });
    fwdBtn.addEventListener('click', () => { audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 30); });

    track.addEventListener('click', (e) => {
      const rect = track.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      if (isFinite(audio.duration)) {
        audio.currentTime = ratio * audio.duration;
      }
    });

    volEl.addEventListener('input', () => { audio.volume = parseFloat(volEl.value); });
    audio.addEventListener('timeupdate', updateTime);
    audio.addEventListener('loadedmetadata', updateTime);
    audio.addEventListener('ended', () => { setPlaying(false); updateTime(); });
  })();
</script>
