---
interface Props {
  src: string;
}
const { src } = Astro.props;
---

<div class="post-audio-player">
  <p class="audio-label">&#127897; Listen to the audio version</p>
  <div class="audio-bar">
    <button class="audio-btn" data-action="play" title="Play">&#9654;</button>
    <button class="audio-btn" data-action="pause" title="Pause" style="display:none">&#9646;&#9646;</button>
    <button class="audio-btn" data-action="stop" title="Stop">&#9632;</button>
    <button class="audio-btn" data-action="back" title="Back 10s">&#9664;&#9664;</button>
    <button class="audio-btn" data-action="fwd" title="Forward 30s">&#9654;&#9654;</button>
    <div class="audio-progress-track" data-role="track">
      <div class="audio-progress-fill" data-role="fill"></div>
    </div>
    <span class="audio-time" data-role="time">0:00 / 0:00</span>
    <span class="audio-vol-icon">&#128266;</span>
    <input type="range" class="audio-volume" data-role="volume" min="0" max="1" step="0.05" value="1" />
  </div>
  <audio data-role="audio" src={src} preload="metadata" style="display:none"></audio>
</div>

<script is:inline>
  (function () {
    var container = document.currentScript.previousElementSibling;
    if (!container) return;

    var audio = container.querySelector('[data-role="audio"]');
    var playBtn = container.querySelector('[data-action="play"]');
    var pauseBtn = container.querySelector('[data-action="pause"]');
    var stopBtn = container.querySelector('[data-action="stop"]');
    var backBtn = container.querySelector('[data-action="back"]');
    var fwdBtn = container.querySelector('[data-action="fwd"]');
    var track = container.querySelector('[data-role="track"]');
    var fill = container.querySelector('[data-role="fill"]');
    var timeEl = container.querySelector('[data-role="time"]');
    var volEl = container.querySelector('[data-role="volume"]');

    function fmt(s) {
      var m = Math.floor(s / 60);
      var sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function updateTime() {
      var dur = isFinite(audio.duration) ? audio.duration : 0;
      fill.style.width = dur ? ((audio.currentTime / dur) * 100) + '%' : '0%';
      timeEl.textContent = fmt(audio.currentTime) + ' / ' + fmt(dur);
    }

    function setPlaying(playing) {
      playBtn.style.display = playing ? 'none' : '';
      pauseBtn.style.display = playing ? '' : 'none';
    }

    playBtn.addEventListener('click', function () { audio.play(); setPlaying(true); });
    pauseBtn.addEventListener('click', function () { audio.pause(); setPlaying(false); });
    stopBtn.addEventListener('click', function () {
      audio.pause();
      audio.currentTime = 0;
      setPlaying(false);
      updateTime();
    });
    backBtn.addEventListener('click', function () { audio.currentTime = Math.max(0, audio.currentTime - 10); });
    fwdBtn.addEventListener('click', function () { audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 30); });

    track.addEventListener('click', function (e) {
      var rect = track.getBoundingClientRect();
      var ratio = (e.clientX - rect.left) / rect.width;
      if (isFinite(audio.duration)) {
        audio.currentTime = ratio * audio.duration;
      }
    });

    volEl.addEventListener('input', function () { audio.volume = parseFloat(volEl.value); });
    audio.addEventListener('timeupdate', updateTime);
    audio.addEventListener('loadedmetadata', updateTime);
    audio.addEventListener('ended', function () { setPlaying(false); updateTime(); });
  })();
</script>
